{
	"name": "@twin-community.org/dataspace-example-app",
	"version": "0.0.1",
	"description": "DS Example App",
	"author": "jose.cantera@iota.org",
	"license": "Apache-2.0",
	"type": "module",
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"clean": "rimraf dist coverage src/schemas",
		"build:compile": "tspc",
		"build": "npm run build:compile",
		"dev": "nodemon --watch src --ext ts --exec \"npm run build\"",
		"test": "vitest --run --config ./vitest.config.ts --no-cache",
		"test:build": "tspc -p ./tests/tsconfig.json --noEmit",
		"validate-locales": "validate-locales",
		"test:coverage": "vitest --run --coverage --config ./vitest.config.ts --no-cache",
		"docs:clean": "rimraf docs/reference",
		"docs:generate": "typedoc --options typedoc.config.mjs",
		"docs": "npm run docs:clean && npm run docs:generate",
		"dist": "npm run clean && npm run build && npm run validate-locales && npm run test:build && npm run test",
		"dist:no-test": "npm run clean && npm run build && npm run test:build"
	},
	"dependencies": {
		"@twin.org/api-models": "next",
		"@twin.org/context": "next",
		"@twin.org/core": "next",
		"@twin.org/data-core": "next",
		"@twin.org/data-json-ld": "next",
		"@twin.org/dataspace-models": "0.0.3-next.29",
		"@twin.org/engine-models": "next",
		"@twin.org/engine-types": "next",
		"@twin.org/logging-models": "next",
		"@twin.org/nameof": "next",
		"@twin.org/standards-dataspace-protocol": "next",
		"@twin.org/standards-w3c-activity-streams": "next",
		"@twin.org/standards-dublin-core": "next"
	},
	"devDependencies": {
		"@twin.org/nameof-transformer": "next",
		"@twin.org/nameof-vitest-plugin": "next",
		"@twin.org/validate-locales": "next",
		"@types/node": "25.9.1",
		"copyfiles": "2.4.1",
		"nodemon": "3.1.14",
		"rimraf": "6.1.3",
		"ts-patch": "4.0.1",
		"typedoc": "0.28.19",
		"typedoc-plugin-markdown": "4.11.0",
		"typescript": "6.0.3",
		"vitest": "4.1.6"
	},
	"main": "./dist/es/index.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/es/index.js",
			"default": "./dist/es/index.js"
		},
		"./locales/*.json": "./locales/*.json"
	},
	"files": [
		"dist/es",
		"dist/types",
		"locales",
		"docs"
	],
	"keywords": [
		"twin",
		"trade",
		"iota",
		"framework",
		"blockchain",
		"dataspace",
		"adapter",
		"integration"
	],
	"homepage": "https://twindev.org"
}
