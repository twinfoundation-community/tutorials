# Enable multi-tenant support, defaults to false.

TWIN_TENANT_ENABLED="true"

# TWIN_FEDERATED_CATALOGUE_REMOTE_ENDPOINT="http://host.docker.internal:3000"

TWIN_FEDERATED_CATALOGUE_ENABLED="true"

# TWIN_PUBLIC_ORIGIN="http://host.docker.internal:3000"


DPI_NODE_DATASPACE_STALLED_NEGOTIATION_TIMEOUT="5"

## How long in minutes a consumer transfer may sit in REQUESTED before it times out.
DPI_NODE_DATASPACE_STALLED_TRANSFER_TIMEOUT="5"
