{
	"name": "@twin-community.org/dataspace-example-app",
	"version": "0.0.1",
	"description": "DS Example App",
	"author": "jose.cantera@iota.org",
	"license": "Apache-2.0",
	"type": "module",
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"clean": "rimraf dist coverage src/schemas",
		"build:compile": "tspc",
		"build": "npm run build:compile",
		"dist": "npm run clean && npm run build",
		"format": "prettier --config prettier.config.mjs --write .",
		"lint:format": "prettier --config prettier.config.mjs --check .",
		"lint:code": "eslint . --cache --cache-location .eslintcache",
		"lint": "npm run lint:format && npm run lint:code"
	},
	"dependencies": {
		"@twin.org/api-models": "next",
		"@twin.org/context": "next",
		"@twin.org/core": "next",
		"@twin.org/data-core": "next",
		"@twin.org/data-json-ld": "next",
		"@twin.org/dataspace-models": "^0.0.3-next.38",
		"@twin.org/engine-models": "next",
		"@twin.org/engine-types": "next",
		"@twin.org/logging-models": "next",
		"@twin.org/nameof": "next",
		"@twin.org/standards-dataspace-protocol": "next",
		"@twin.org/standards-w3c-activity-streams": "next",
		"@twin.org/standards-dublin-core": "next",
		"@twin.org/auditable-item-graph-models": "next"
	},
	"devDependencies": {
		"@twin.org/nameof-transformer": "next",
		"@twin.org/nameof-vitest-plugin": "next",
		"@types/node": "25.9.1",
		"copyfiles": "2.4.1",
		"rimraf": "6.1.3",
		"ts-patch": "4.0.1",
		"typescript": "6.0.3",
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "10.0.1",
		"@stylistic/eslint-plugin": "5.10.0",
		"@typescript-eslint/eslint-plugin": "8.59.4",
		"eslint": "10.4.0",
		"eslint-config-prettier": "10.1.8",
		"@tony.ganchev/eslint-plugin-header": "3.4.4",
		"eslint-plugin-import-x": "4.16.2",
		"eslint-plugin-jsdoc": "63.0.0",
		"eslint-plugin-prettier": "5.5.5",
		"eslint-plugin-promise": "7.3.0",
		"eslint-plugin-simple-import-sort": "13.0.0",
		"eslint-plugin-unicorn": "64.0.0",
		"eslint-plugin-unused-imports": "4.4.1",
		"globals": "17.6.0",
		"prettier": "3.8.3"
	},
	"main": "./dist/es/index.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/es/index.js",
			"default": "./dist/es/index.js"
		},
		"./locales/*.json": "./locales/*.json"
	},
	"files": [
		"dist/es",
		"dist/types"
	],
	"keywords": [
		"twin",
		"trade",
		"iota",
		"framework",
		"blockchain",
		"dataspace",
		"adapter",
		"integration"
	],
	"homepage": "https://twindev.org"
}
