## The features to enable on the node
##   node-identity: generates an identity for the node if not provided in config.
##   node-admin-user: generates an admin user for the node if not provided in config.
##   node-wallet: generates a wallet for the node if a faucet is available.
TWIN_FEATURES="node-identity,node-admin-user,node-wallet"

TWIN_ADMIN_USER_NAME="admin@node"
# Username for Node admin login, defaults to randomly generated, check logs for the generated password
TWIN_ADMIN_USER_PASSWORD="1234-A-1234-b-1234"
