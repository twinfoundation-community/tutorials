#----------------------------- Node Config -----------------------------#

# Web Server

TWIN_PORT=3000
TWIN_HOST="0.0.0.0"
# TWIN_CORS_ORIGINS=*
# TWIN_HTTP_METHODS=
# TWIN_HTTP_ALLOWED_HEADERS=
# TWIN_HTTP_EXPOSED_HEADERS=
# TWIN_PUBLIC_ORIGIN="https://api.example.com:3000"

# Global

## Set DEBUG to true to enable additional information in the logs
TWIN_DEBUG=true

## Enable the node having a unique ID, defaults to true.
# TWIN_NODE_IDENTITY_ENABLED="true"

# Storage

## Storage for files will use this directory as its root, in docker you should map this to a mounted volume to be persistent
TWIN_STORAGE_FILE_ROOT="/var/lib/twin"

## The file name of the state file, if this file does not exist it will be created with the bootstrap process
# TWIN_STATE_FILENAME="engine-state.json"

#----------------------------- Connector Config -----------------------------#

# MySQL Storage Connector

TWIN_MY_SQL_HOST=mysql
TWIN_MY_SQL_PORT=3306
TWIN_MY_SQL_USER="twin"
TWIN_MY_SQL_PASSWORD="twin"
TWIN_MY_SQL_DATABASE="twin"

# IOTA DLT

TWIN_IOTA_NODE_ENDPOINT="https://api.testnet.iota.cafe"
TWIN_IOTA_FAUCET_ENDPOINT="https://faucet.testnet.iota.cafe"
TWIN_IOTA_EXPLORER_ENDPOINT="https://explorer.iota.org/"
TWIN_IOTA_NETWORK="testnet"
TWIN_IOTA_COIN_TYPE="4218"
# TWIN_IOTA_GAS_STATION_ENDPOINT="http://localhost:9527"
# TWIN_IOTA_GAS_STATION_AUTH_TOKEN="qEyCL6d9BKKFl/tfDGAKeGFkhUlf7FkqiGV7Xw4JUsI="

# Hashicorp Vault Connector

# TWIN_HASHICORP_VAULT_ENDPOINT=""
# TWIN_HASHICORP_VAULT_TOKEN=""

#----------------------------- Connector Types -----------------------------#

# Entity Storage

## Entity Storage can be a comma separated list [file, memory, aws-dynamodb, azure-cosmosdb, gcp-firestoredb, scylladb, postgresql, mysql, mongodb, synchronised]
TWIN_ENTITY_STORAGE_CONNECTOR_TYPE="mysql"

## Entity Storage Connector default connector, defaults to the first connector in the list
# TWIN_ENTITY_STORAGE_CONNECTOR_DEFAULT=""

## Entity Storage connector to use for which has the synchronisation feature
# TWIN_ENTITY_STORAGE_CONNECTOR_SYNCHRONISED=""

## Prefix to add to tables in entity storage to separate the data from instances e.g. my-node-
# TWIN_ENTITY_STORAGE_TABLE_PREFIX=""

# Blob Storage

## Blob Storage can be a comma separated list [memory, file, ipfs, aws-s3, azure-storage, gcp-storage]
TWIN_BLOB_STORAGE_CONNECTOR_TYPE="file"

## Blob Storage Connector default connector, defaults to the first connector in the list
# TWIN_BLOB_STORAGE_CONNECTOR_DEFAULT=""

## Blob Storage connector to use when it requires public access, e.g. for synchronised storage
# TWIN_BLOB_STORAGE_CONNECTOR_PUBLIC=""

## Prefix to add to directories in blob storage
# TWIN_BLOB_STORAGE_PREFIX=""

## Enable encryption for blob storage, this will encrypt the data before storing it
TWIN_BLOB_STORAGE_ENABLE_ENCRYPTION=true

## The key id to use in the vault for encryption
# TWIN_BLOB_STORAGE_ENCRYPTION_KEY_ID="blob-encryption"

# Logging Connector

## Logging Connector [console,entity-storage]
## You can log to more than one connector my separating them with a comma
TWIN_LOGGING_CONNECTOR="console"

# Vault Connector

## Vault Connector [entity-storage, hashicorp]
TWIN_VAULT_CONNECTOR="entity-storage"

## Prefix to prepend to entries in the vault.
# TWIN_VAULT_PREFIX=""

# Event Bus Connector

## Event Bus Connector [local]
TWIN_EVENT_BUS_CONNECTOR="local"

# Telemetry Connector

## Telemetry Connector [entity-storage]
TWIN_TELEMETRY_CONNECTOR="entity-storage"

# Faucet Connector

## Faucet Connector Connector [entity-storage, iota]
TWIN_FAUCET_CONNECTOR="iota"

# Wallet Connector

## Wallet Connector Connector [entity-storage, iota]
TWIN_WALLET_CONNECTOR="iota"

# Verifiable Storage Connector

## Verifiable Storage Connector [entity-storage, iota]
TWIN_VERIFIABLE_STORAGE_CONNECTOR="iota"

# NFT Connector

## NFT Connector [entity-storage, iota]
TWIN_NFT_CONNECTOR="iota"

# Identity Resolver Connector

## Identity Resolver Connector [entity-storage, iota, universal]
TWIN_IDENTITY_RESOLVER_CONNECTOR="iota"

## Endpoint for universal resolver
# TWIN_UNIVERSAL_RESOLVER_ENDPOINT=""

# Identity Connector

## Identity Connector [entity-storage, iota]
TWIN_IDENTITY_CONNECTOR="iota"

## The index of the wallet address to use, defaults to 0.
# TWIN_IDENTITY_WALLET_ADDRESS_INDEX="0"

# Identity Profile Connector

## Identity Profile Connector [entity-storage]
TWIN_IDENTITY_PROFILE_CONNECTOR="entity-storage"

# Immutable Proof

## The assertion method from the identity to use in immutable proof operations
# TWIN_IMMUTABLE_PROOF_ASSERTION_METHOD_ID="immutable-proof-assertion"

# Attestation

## Attestation Connector Connector [nft]
TWIN_ATTESTATION_CONNECTOR="nft"

## The attestation assertion method to use from the DID
# TWIN_ATTESTATION_ASSERTION_METHOD_ID="attestation-assertion"

# Auth Processor

## Auth Admin Type [entity-storage]
TWIN_AUTH_ADMIN_PROCESSOR_TYPE="entity-storage"

## Auth Type [entity-storage]
TWIN_AUTH_PROCESSOR_TYPE="entity-storage"

## The key to use for signing in auth operations
# TWIN_AUTH_SIGNING_KEY_ID="auth-signing"

# Messaging

## Enable messaging, defaults to false.
# TWIN_MESSAGING_ENABLED="false"

## Messaging Email Connector Connector [entity-storage, aws]
# TWIN_MESSAGING_EMAIL_CONNECTOR="entity-storage"

## Messaging SMS Connector Connector [entity-storage, aws]
# TWIN_MESSAGING_SMS_CONNECTOR="entity-storage"

## Messaging Push Notifications Connector Connector [entity-storage, aws]
# TWIN_MESSAGING_PUSH_NOTIFICATIONS_CONNECTOR="entity-storage"

## The AWS Application for push notifications - use the @json: prefix to specify the path to the JSON file.
# TWIN_AWS_MESSAGING_PUSH_NOTIFICATION_APPLICATIONS="@json:aws-ses-apps.json"

# Data Processing

## Data Processing enabled, defaults to false.
TWIN_DATA_PROCESSING_ENABLED="true"

## Data Converters [json,xml]
TWIN_DATA_CONVERTER_CONNECTORS="json,xml"

## Data Extractors [json-path]
TWIN_DATA_EXTRACTOR_CONNECTORS="json-path"

# Auditable Item Graph

## Is the auditable item graph enabled, defaults to false.
TWIN_AUDITABLE_ITEM_GRAPH_ENABLED="true"

# Auditable Item Stream

## Is the auditable item stream enabled, defaults to false.
TWIN_AUDITABLE_ITEM_STREAM_ENABLED="true"

# Document Management

## Is the document management enabled, defaults to false.
TWIN_DOCUMENT_MANAGEMENT_ENABLED="true"

# Trust

## Is the trust feature enabled, defaults to false.
TWIN_TRUST_ENABLED="true"

## The trust generators to enable, comma separated list of module types e.g. jwt-verifiable-credential
# TWIN_TRUST_GENERATORS="jwt-verifiable-credential"

## The trust verifiers to enable, comma separated list of module types e.g. jwt-verifiable-credential
TWIN_TRUST_VERIFIERS="jwt-verifiable-credential"

## The verification method to use for trust identities, defaults to trust-assertion.
# TWIN_TRUST_VERIFICATION_METHOD_ID="trust-assertion"

## The time to live for trust JWTs generation in seconds, defaults to undefined for never expiring.
# TWIN_TRUST_JWT_TTL_SECONDS="3600"

# Synchronised Storage

# TWIN_SYNCHRONISED_STORAGE_ENABLED="false"

## If this is not a trusted node we need to point the synchronised storage service to a node that can support trusted storage
# TWIN_SYNCHRONISED_STORAGE_TRUSTED_URL=""

## If you want to use a custom verifiable storage key ID for synchronised storage you can supply an id here
## The default is to use the network name and the inbuilt verifiable storage ids.
# TWIN_SYNCHRONISED_STORAGE_VERIFIABLE_STORAGE_KEY_ID=""

## The key from the vault which is used to encrypt the synchronised storage blobs.
## Only required for trusted nodes, as regular nodes will request from the trusted nodes.
# TWIN_SYNCHRONISED_STORAGE_BLOB_STORAGE_ENCRYPTION_KEY_ID="synchronised-storage-blob-encryption-key"

## The private key used for blob encryption in synchronised storage ChaCha20Poly1305 in base64 format.
## Only required for trusted nodes, as regular nodes will not write encrypted data.
# TWIN_SYNCHRONISED_STORAGE_BLOB_STORAGE_KEY=""

## How often to check for entity updates in minutes.
# TWIN_SYNCHRONISED_STORAGE_ENTITY_UPDATE_INTERVAL_MINUTES="5"

## Interval to perform consolidation of changesets, only used if this is a trusted node.
# TWIN_SYNCHRONISED_STORAGE_CONSOLIDATION_INTERVAL_MINUTES="60"

## The number of entities to process in a single consolidation batch, only used if this is a trusted node.
# TWIN_SYNCHRONISED_STORAGE_CONSOLIDATION_BATCH_SIZE="1000"

## The maximum number of consolidations to keep in storage, only used if this is a trusted node.
# TWIN_SYNCHRONISED_STORAGE_MAX_CONSOLIDATIONS="5"

# Federated Catalog

# TWIN_FEDERATED_CATALOGUE_ENABLED="true"

## Federated catalog filters, command separated list of filters to add.
TWIN_FEDERATED_CATALOGUE_FILTERS="filter-by-metadata"


## What is the callback path for rights management negotiations e.g. /rights-management.
# TWIN_RIGHTS_MANAGEMENT_CALLBACK_PATH="/rights-management"

## Policy Information Sources - use command separated lists of module types e.g. static,identity
# TWIN_RIGHTS_MANAGEMENT_POLICY_INFORMATION_SOURCES="static,identity"

## Policy Negotiators - use command separated lists of module types e.g. example
# TWIN_RIGHTS_MANAGEMENT_POLICY_NEGOTIATORS="example"

## Policy Requesters - use command separated lists of module types e.g. example
# TWIN_RIGHTS_MANAGEMENT_POLICY_REQUESTERS="example"

## Policy Execution Actions - use command separated lists of module types e.g. logging
# TWIN_RIGHTS_MANAGEMENT_POLICY_EXECUTION_ACTIONS="logging"

## Policy Enforcement Processors - use command separated lists of module types e.g. example
# TWIN_RIGHTS_MANAGEMENT_POLICY_ENFORCEMENT_PROCESSORS="example"

## Policy Arbiters - use command separated lists of module types e.g. example
# TWIN_RIGHTS_MANAGEMENT_POLICY_ARBITERS="example"

## Task Scheduler
TWIN_TASK_SCHEDULER_ENABLED="true"

## Data Space Connector
TWIN_DATASPACE_ENABLED="true"

## The length of time to retain the activity logs for in minutes, set to -1 to keep forever.
# TWIN_DATA_SPACE_CONNECTOR_RETAIN_ACTIVITY_LOGS_FOR="10"

## The interval for cleaning up the activity logs.
# TWIN_DATA_SPACE_CONNECTOR_ACTIVITY_LOGS_CLEANUP_INTERVAL="60"

## REST and Socket Route Processors

## Include the full body in the route logging, defaults to false unless debug is true
# TWIN_ROUTE_LOGGING_INCLUDE_BODY="false"

## Include the full base64 content in the route logging, defaults to false
# TWIN_ROUTE_LOGGING_FULL_BASE64="false"

## List of properties to obfuscate in the route logging, comma separated, defaults to "password"
# TWIN_ROUTE_LOGGING_OBFUSCATE_PROPERTIES="password,token,onboardingToken"

TWIN_NOTARIZATION_CONNECTOR="iota"

TWIN_DATASPACE_AUTO_START_TRANSFERS="true"

TWIN_DATASPACE_DATA_PLANE_PATH="dataspace/entities"

TWIN_LOGGING_SILENT_COMPONENTS="EntityStorageTelemetryConnector,TaskSchedulerService"
