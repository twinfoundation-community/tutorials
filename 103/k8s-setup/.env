#----------------------------- Node Config -----------------------------#
# All-local profile (entity-storage connectors, no IOTA). This is the same profile as
# 101/docker-setup/.env.local, with the host/origin pointed at the in-cluster service.
#
# NOTE: TWIN_STORAGE_FILE_ROOT below is duplicated as a real container env var in
# twin-node.yaml. The container env is what actually takes effect (the image bakes its own
# value which a .env FILE cannot override) - keep the two in sync.

# Web Server

TWIN_PORT=3000
TWIN_HOST="0.0.0.0"
TWIN_PUBLIC_ORIGIN="http://twin.example.com/"

# Global

TWIN_DEBUG=true

## Enable multi-tenant support.
TWIN_TENANT_ENABLED="true"

# Storage (see note above - also set as a container env in twin-node.yaml)
TWIN_STORAGE_FILE_ROOT="/var/lib/twin"

#----------------------------- Connector Config -----------------------------#

# MySQL Storage Connector

TWIN_MY_SQL_HOST=twin-node-db.twin.svc.cluster.local
TWIN_MY_SQL_PORT=3306
TWIN_MY_SQL_USER="twin"
TWIN_MY_SQL_PASSWORD="twin"
TWIN_MY_SQL_DATABASE="twin"

#----------------------------- Connector Types -----------------------------#

# Entity Storage [file, memory, mysql, postgresql, mongodb, ...]
TWIN_ENTITY_STORAGE_CONNECTOR_TYPE="mysql"

# Blob Storage [memory, file, ipfs, aws-s3, azure-storage, gcp-storage]
TWIN_BLOB_STORAGE_CONNECTOR_TYPE="file"
TWIN_BLOB_STORAGE_ENABLE_ENCRYPTION=true

# Logging Connector [console, entity-storage]
TWIN_LOGGING_CONNECTOR="console"

# Vault Connector [entity-storage, hashicorp]
TWIN_VAULT_CONNECTOR="entity-storage"

# Event Bus Connector [local]
TWIN_EVENT_BUS_CONNECTOR="local"

# Telemetry Connector [entity-storage]
TWIN_TELEMETRY_CONNECTOR="entity-storage"

######### All Local ##################
######################################
TWIN_FAUCET_CONNECTOR="entity-storage"
TWIN_WALLET_CONNECTOR="entity-storage"
TWIN_VERIFIABLE_STORAGE_CONNECTOR="entity-storage"
TWIN_NFT_CONNECTOR="entity-storage"
TWIN_IDENTITY_RESOLVER_CONNECTOR="entity-storage"
TWIN_IDENTITY_CONNECTOR="entity-storage"
TWIN_IDENTITY_PROFILE_CONNECTOR="entity-storage"
TWIN_NOTARIZATION_CONNECTOR="entity-storage"
######################################

# Attestation Connector [nft]
TWIN_ATTESTATION_CONNECTOR="nft"

# Auth Processors [entity-storage]
TWIN_AUTH_ADMIN_PROCESSOR_TYPE="entity-storage"
TWIN_AUTH_PROCESSOR_TYPE="entity-storage"

# Data Processing
TWIN_DATA_PROCESSING_ENABLED="true"
TWIN_DATA_CONVERTER_CONNECTORS="json,xml"
TWIN_DATA_EXTRACTOR_CONNECTORS="json-path"

# Components
TWIN_AUDITABLE_ITEM_GRAPH_ENABLED="true"
TWIN_AUDITABLE_ITEM_STREAM_ENABLED="true"
TWIN_DOCUMENT_MANAGEMENT_ENABLED="true"
TWIN_TRUST_ENABLED="true"
TWIN_TRUST_VERIFIERS="jwt-verifiable-credential"
TWIN_FEDERATED_CATALOGUE_ENABLED="true"
TWIN_RIGHTS_MANAGEMENT_ENABLED="true"
TWIN_BACKGROUND_TASKS_ENABLED="true"
TWIN_TASK_SCHEDULER_ENABLED="true"
TWIN_DATASPACE_ENABLED="true"
